#dev, prod
ENV="dev"

HOST="0.0.0.0"
APP_PORT=80
HOST_PORT=3000
WRITE_TIMEOUT=500ms
READ_TIMEOUT=500ms
IDLE_TIMEOUT=5s
SHUTDOWN_TIMEOUT=1s

DB_HOST=postgres
DB_PORT=5432
